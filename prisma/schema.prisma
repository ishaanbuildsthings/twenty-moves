generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String   @id @default(cuid())
  supabaseId        String   @unique
  username          String   @unique
  firstName         String
  lastName          String
  wcaId             String?
  profilePictureUrl String?
  country           String?
  bio               String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tournamentEntries DailyTournamentEntry[]
  followers         Follow[]               @relation("followee")
  following         Follow[]               @relation("follower")
}

// A reusable group of scrambles. Used by tournaments, races, and
// head-to-head battles so all participants solve the same scrambles.
model ScrambleSet {
  id        String   @id @default(cuid())
  event     String   // CubeEvent enum value (e.g. "333", "222")
  scrambles Json     // Array of scramble strings
  count     Int      // Number of scrambles in the set
  createdAt DateTime @default(now())

  dailyTournaments DailyTournament[]
}

// One tournament per event per day. Links to a shared ScrambleSet.
model DailyTournament {
  id            String   @id @default(cuid())
  date          String   // UTC date string, e.g. "2026-03-26"
  event         String   // CubeEvent enum value
  scrambleSetId String
  createdAt     DateTime @default(now())

  scrambleSet ScrambleSet            @relation(fields: [scrambleSetId], references: [id])
  entries     DailyTournamentEntry[]

  @@unique([date, event])
}

// One entry per user per tournament. Tracks their solves and result.
model DailyTournamentEntry {
  id           String    @id @default(cuid())
  tournamentId String
  userId       String
  results      Json      @default("[]") // Array of { timeMs: number, penalty: string | null }
  average      Int?      // Computed after all solves complete. Null while in progress.
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  tournament DailyTournament @relation(fields: [tournamentId], references: [id])
  user       User            @relation(fields: [userId], references: [id])

  @@unique([tournamentId, userId])
}

model Follow {
  id         String   @id @default(cuid())
  followerId String
  followeeId String
  createdAt  DateTime @default(now())

  follower User @relation("follower", fields: [followerId], references: [id])
  followee User @relation("followee", fields: [followeeId], references: [id])

  @@unique([followerId, followeeId])
}
