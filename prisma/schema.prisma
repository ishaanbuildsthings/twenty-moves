generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(cuid())
  supabaseId String   @unique
  username   String   @unique
  firstName String
  lastName  String
  wcaId             String?
  profilePictureUrl String?
  country           String?
  bio               String   @default("")
  createdAt         DateTime @default(now())
  updatedAt DateTime @updatedAt

  solves            Solve[]
  personalBests     PersonalBest[]
  followers         Follow[]          @relation("followee")
  following         Follow[]          @relation("follower")
  tournamentEntries TournamentEntry[]
  practicePosts     PracticePost[]
  postLikes         PostLike[]
}

model Event {
  id   String @id @default(cuid())
  name String @unique

  solves            Solve[]
  personalBests     PersonalBest[]
  scrambleSets      ScrambleSet[]
  tournamentEntries TournamentEntry[]
  practicePosts     PracticePost[]
}


enum PbType {
  single
  mo3
  avg5
  avg12
  avg100
}

model PersonalBest {
  id      String @id @default(cuid())
  userId  String
  eventId String
  time    String
  type    PbType

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId, type])
}

enum Penalty {
  plus_two
  dnf
}

model Solve {
  id              String   @id @default(cuid())
  userId          String
  eventId         String
  scrambleSetId   String
  scrambleSetIndex Int
  time            Float
  penalty         Penalty?
  createdAt       DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id])
  event       Event        @relation(fields: [eventId], references: [id])
  scrambleSet ScrambleSet  @relation(fields: [scrambleSetId], references: [id])
}

// One tournament per day. Covers all events.
// Individual events are tracked via TournamentEntry + ScrambleSet.
model Tournament {
  id        String            @id @default(cuid())
  number    Int               @unique
  name      String?           // Optional display name override (e.g. "Holiday Special")
  datePST   String   @unique  // PST date string, e.g. "2026-03-26". The tournament "day" in Pacific time.
  createdAt DateTime          @default(now())

  entries     TournamentEntry[]
  scrambleSets ScrambleSet[]
}

model ScrambleSet {
  id            String   @id @default(cuid())
  eventId       String
  tournamentId  String?  // Set for tournament scramble sets, null for practice posts.
  scrambles     Json     // String[] — ordered list of move strings
  createdAt     DateTime @default(now())

  event         Event             @relation(fields: [eventId], references: [id])
  tournament    Tournament?       @relation(fields: [tournamentId], references: [id])
  entries       TournamentEntry[]
  solves        Solve[]
  practicePosts PracticePost[]

  // One scramble set per event per tournament.
  @@unique([tournamentId, eventId])
}

model TournamentEntry {
  id            String   @id @default(cuid())
  userId        String
  tournamentId  String
  eventId       String
  scrambleSetId String
  result        Int?    // Cached result in ms for leaderboard sorting.
                        // null = in progress (not enough solves yet).
                        // 999_999_999 (DNF_RESULT) = completed but DNF.
  createdAt     DateTime @default(now())

  user         User        @relation(fields: [userId], references: [id])
  tournament   Tournament  @relation(fields: [tournamentId], references: [id])
  event        Event       @relation(fields: [eventId], references: [id])
  scrambleSet  ScrambleSet @relation(fields: [scrambleSetId], references: [id])

  @@unique([userId, tournamentId, eventId, scrambleSetId])
}

enum PostType {
  practice
  tournament
  race
}

model PracticePost {
  id            String  @id @default(cuid())
  userId        String
  eventId       String
  caption       String  @default("")
  bestSingle    Int?
  bestAo5       Int?
  bestAo12      Int?
  bestAo100     Int?
  sessionMean   Int?
  bestMo3       Int?
  scrambleSetId  String
  displaySolves      Int[]
  numSolves   Int
  numLikes    Int
  numComments Int
  youtubeUrl  String?
  createdAt     DateTime @default(now())
  lastUpdatedAt DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  event       Event       @relation(fields: [eventId], references: [id])
  scrambleSet ScrambleSet @relation(fields: [scrambleSetId], references: [id])
  likes       PostLike[]

  @@index([userId, createdAt(sort: Desc)])
}

model PostLike {
  id     String @id @default(cuid())
  userId String
  postId String
  createdAt DateTime @default(now())

  user User          @relation(fields: [userId], references: [id])
  post PracticePost  @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

model Follow {
  id         String   @id @default(cuid())
  followerId String
  followeeId String
  createdAt  DateTime @default(now())

  follower User @relation("follower", fields: [followerId], references: [id])
  followee User @relation("followee", fields: [followeeId], references: [id])

  @@unique([followerId, followeeId])
}
