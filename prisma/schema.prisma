generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(cuid())
  supabaseId String   @unique
  username   String   @unique
  firstName String
  lastName  String
  wcaId             String?
  profilePictureUrl String?
  country           String?
  bio               String   @default("")
  createdAt         DateTime @default(now())
  updatedAt DateTime @updatedAt

  solves            Solve[]
  personalBests     PersonalBest[]
  followers         Follow[]          @relation("followee")
  following         Follow[]          @relation("follower")
  tournamentEntries TournamentEntry[]
}

model Event {
  id   String @id @default(cuid())
  name String @unique

  solves            Solve[]
  scrambles         Scramble[]
  personalBests     PersonalBest[]
  tournaments       Tournament[]
  scrambleSets      ScrambleSet[]
  tournamentEntries TournamentEntry[]
}

model Scramble {
  id      String @id @default(cuid())
  eventId String
  moves   String

  event  Event   @relation(fields: [eventId], references: [id])
  solves Solve[]
}

enum PbType {
  single
  avg5
  avg12
  avg50
  avg100
}

model PersonalBest {
  id      String @id @default(cuid())
  userId  String
  eventId String
  time    String
  type    PbType

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId, type])
}

enum Penalty {
  plus_two
  dnf
}

model Solve {
  id              String   @id @default(cuid())
  userId          String
  eventId         String
  scrambleSetId   String
  scrambleSetIndex Int
  time            Float
  penalty         Penalty?
  createdAt       DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id])
  event       Event        @relation(fields: [eventId], references: [id])
  scramble    Scramble     @relation(fields: [scrambleId], references: [id])
  scrambleSet ScrambleSet? @relation(fields: [scrambleSetId], references: [id])
}

model Tournament {
  id        String            @id @default(cuid())
  eventId   String
  date      DateTime
  createdAt DateTime          @default(now())

  event   Event               @relation(fields: [eventId], references: [id])
  entries TournamentEntry[]
}

model ScrambleSet {
  id        String   @id @default(cuid())
  eventId   String
  scrambles Json     // String[] — ordered list of move strings
  createdAt DateTime @default(now())

  event   Event             @relation(fields: [eventId], references: [id])
  entries TournamentEntry[]
  solves  Solve[]
}

model TournamentEntry {
  id            String   @id @default(cuid())
  userId        String
  tournamentId  String
  eventId       String
  scrambleSetId String
  result        Int     // ms — ao5 or mo3 depending on tournament.format
  createdAt     DateTime @default(now())

  user         User        @relation(fields: [userId], references: [id])
  tournament   Tournament  @relation(fields: [tournamentId], references: [id])
  event        Event       @relation(fields: [eventId], references: [id])
  scrambleSet  ScrambleSet @relation(fields: [scrambleSetId], references: [id])

  @@unique([userId, tournamentId, eventId, scrambleSetId])
}

model Follow {
  id         String   @id @default(cuid())
  followerId String
  followeeId String
  createdAt  DateTime @default(now())

  follower User @relation("follower", fields: [followerId], references: [id])
  followee User @relation("followee", fields: [followeeId], references: [id])

  @@unique([followerId, followeeId])
}
